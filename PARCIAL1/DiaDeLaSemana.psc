Algoritmo DiaDeLaSemana
	Definir num Como Entero
	escribir "Ingrese un numero del 1 al 7"
	Leer num
	Segun num Hacer
		1:
			Escribir "Lunes"
		2:
			escribir "martes"
		3:
			escribir " miercoles"
		4:
			escribir "jueves"
		5:
			escribir "viernes"
		6:
			escribir " sabado"
		7:
			escribir "domingo"
		De Otro Modo:
			escribir " Numero invalido"
			
			
	FinSegun
	
FinAlgoritmo
