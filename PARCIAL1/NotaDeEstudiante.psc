Algoritmo NotaDeEstudiante
	Definir nota Como Entero
	
	Escribir "Ingrese la nota  (0 a 10) "
	
	Leer nota
	Si nota >= 6 Entonces
		escribir " aprobado"
	SiNo
		si nota <= 4 Entonces
			escribir "reprobado"
		Sino 
			si nota  = 5
				
			FinSi
			escribir"recuperacion"
		FinSi
		
	FinSi
	
FinAlgoritmo
